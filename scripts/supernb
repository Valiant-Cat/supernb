#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SUBCOMMAND="${1:-}"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/supernb <command> [args]

Commands:
  bootstrap
  update
  update-upstreams
  install-codex
  install-claude-code
  install-opencode
  verify-installs
  verify-claude-loop
  init-initiative
  run
  execute-next
  apply-execution
  import-execution
  record-result
  advance-phase
  certify-phase
  upgrade-artifacts
  migrate-legacy
  clean-initiative
  debug-log
  prompt-sync
  test
  show-command
  render-command
  save-command
  init-i18n
  check-copy
  build-impeccable
EOF
}

if [[ -z "${SUBCOMMAND}" ]]; then
  usage >&2
  exit 1
fi

shift || true

case "${SUBCOMMAND}" in
  bootstrap) exec "${ROOT_DIR}/scripts/bootstrap-supernb.sh" "$@" ;;
  update) exec "${ROOT_DIR}/scripts/update-supernb.sh" "$@" ;;
  update-upstreams) exec "${ROOT_DIR}/scripts/update-upstreams.sh" "$@" ;;
  install-codex) exec "${ROOT_DIR}/scripts/install-codex.sh" "$@" ;;
  install-claude-code) exec "${ROOT_DIR}/scripts/install-claude-code.sh" "$@" ;;
  install-opencode) exec "${ROOT_DIR}/scripts/install-opencode.sh" "$@" ;;
  verify-installs) exec python3 "${ROOT_DIR}/scripts/supernb-verify-installs.py" "$@" ;;
  verify-claude-loop) exec python3 "${ROOT_DIR}/scripts/supernb-verify-claude-loop.py" "$@" ;;
  init-initiative) exec "${ROOT_DIR}/scripts/init-initiative.sh" "$@" ;;
  run) exec python3 "${ROOT_DIR}/scripts/supernb-run.py" "$@" ;;
  execute-next) exec python3 "${ROOT_DIR}/scripts/supernb-execute-next.py" "$@" ;;
  apply-execution) exec python3 "${ROOT_DIR}/scripts/supernb-apply-execution.py" "$@" ;;
  import-execution) exec python3 "${ROOT_DIR}/scripts/supernb-import-execution.py" "$@" ;;
  record-result) exec python3 "${ROOT_DIR}/scripts/supernb-record-result.py" "$@" ;;
  advance-phase) exec python3 "${ROOT_DIR}/scripts/supernb-advance-phase.py" "$@" ;;
  certify-phase) exec python3 "${ROOT_DIR}/scripts/supernb-certify-phase.py" "$@" ;;
  upgrade-artifacts) exec python3 "${ROOT_DIR}/scripts/supernb-upgrade-artifacts.py" "$@" ;;
  migrate-legacy) exec python3 "${ROOT_DIR}/scripts/supernb-migrate-legacy.py" "$@" ;;
  clean-initiative) exec python3 "${ROOT_DIR}/scripts/supernb-clean-initiative-artifacts.py" "$@" ;;
  debug-log) exec python3 "${ROOT_DIR}/scripts/supernb-debug-log.py" "$@" ;;
  prompt-sync) exec python3 "${ROOT_DIR}/scripts/supernb-prompt-sync.py" "$@" ;;
  test) exec python3 -m unittest discover -s "${ROOT_DIR}/tests" "$@" ;;
  show-command) exec "${ROOT_DIR}/scripts/show-command-template.sh" "$@" ;;
  render-command) exec "${ROOT_DIR}/scripts/render-command.sh" "$@" ;;
  save-command) exec "${ROOT_DIR}/scripts/save-command-brief.sh" "$@" ;;
  init-i18n) exec "${ROOT_DIR}/scripts/init-i18n-foundation.sh" "$@" ;;
  check-copy) exec "${ROOT_DIR}/scripts/check-no-hardcoded-copy.sh" "$@" ;;
  build-impeccable) exec "${ROOT_DIR}/scripts/build-impeccable-dist.sh" "$@" ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown supernb command: ${SUBCOMMAND}" >&2
    usage >&2
    exit 1
    ;;
esac
